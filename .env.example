# Copy this file to .env in the project root:
#   cp .env.example .env
#
# .env is gitignored and used for LOCAL runs only.
# For production, set the same variables in your host dashboard (see below).

# --- Local server (Render / npm start) ---
PORT=3000
USE_HTTPS=false

# Who may call the API from a browser (your website).
# Render: paste this in Environment → CORS_ORIGIN
CORS_ORIGIN=https://huddlance.com,https://www.huddlance.com

# --- Frontend build (Vercel) ---
# Your Render Web Service URL (no trailing slash).
# Vercel: Settings → Environment Variables → BACKEND_URL
BACKEND_URL=https://your-app.onrender.com
